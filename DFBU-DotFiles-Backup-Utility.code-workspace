{
  "folders": [
    {
      "path": ".",
    },
  ],
  "settings": {
    // Python Configuration
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    // Sole LSP = basedpyright (the only installed Python language server). "None"
    // keeps ms-python's server off. Pylance python.analysis.* and mypy-type-checker.*
    // editor keys removed 2026-06-07 — neither extension is installed; basedpyright
    // runs in-editor, mypy still runs in CI.
    "python.languageServer": "None",
    // Ruff Configuration (Linter & Formatter)
    "[python]": {
      "editor.defaultFormatter": "charliermarsh.ruff",
      "editor.formatOnSave": true,
      "editor.codeActionsOnSave": {
        "source.organizeImports.ruff": "explicit",
        "source.fixAll.ruff": "explicit",
      },
    },
    // Ruff Extension Settings
    "ruff.enable": true,
    "ruff.lint.enable": true,
    "ruff.path": ["${workspaceFolder}/.venv/bin/ruff"],
    "ruff.importStrategy": "fromEnvironment",
    // File Associations
    "files.associations": {
      "*.toml": "toml",
      "*.ui": "xml",
      "*.yaml": "yaml",
      "*.yml": "yaml",
      ".mypy-strict-config.md": "markdown",
      "requirements.txt": "pip-requirements",
    },
    // Editor Settings for Python
    "editor.rulers": [88],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.trimAutoWhitespace": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    // UV Toolkit Configuration
    // uv is a system-level tool, not installed in the venv
    "uvToolkit.uvPath": "uv",
    "uvToolkit.autoActivate": true,
    "uvToolkit.showNotifications": true,
    // Even Better TOML Configuration
    "evenBetterToml.formatter.alignEntries": false,
    "evenBetterToml.formatter.allowedBlankLines": 1,
    "evenBetterToml.formatter.columnWidth": 88,
    "evenBetterToml.schema.associations": {
      "pyproject.toml": "https://json.schemastore.org/pyproject.json",
    },
    "[toml]": {
      "editor.defaultFormatter": "tamasfe.even-better-toml",
      "editor.formatOnSave": true,
    },
    // Python Test Explorer Configuration
    "pythonTestExplorer.testFramework": "pytest",
    "pythonTestExplorer.testplanEnabled": false,
    // Test Configuration
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": ["DFBU/tests", "-v", "--tb=short"],
    // File Exclusions
    "files.exclude": {
      "**/__pycache__": true,
      "**/.pytest_cache": true,
      "**/.ruff_cache": true,
      "**/.mypy_cache": true,
      "**/*.pyc": true,
      "**/*.pyo": true,
      "**/*.egg-info": true,
    },
    // Search Exclusions
    "search.exclude": {
      "**/__pycache__": true,
      "**/.pytest_cache": true,
      "**/.ruff_cache": true,
      "**/.mypy_cache": true,
      "**/venv": true,
      "**/.venv": true,
    },
    "chat.tools.terminal.autoApprove": {
      "pytest": true,
    },
    "chatgpt.commentCodeLensEnabled": false,
  },
}
